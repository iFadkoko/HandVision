<Window x:Class="HandVision.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="HandVision — C# + Python OpenCV Hand Tracking" 
        Height="720" Width="1200"
        MinHeight="600" MinWidth="900"
        WindowStartupLocation="CenterScreen"
        Background="{StaticResource BgDeep}"
        Loaded="Window_Loaded"
        Closing="Window_Closing">

    <Grid>
        <Grid.RowDefinitions>
            <!-- Top Nav Bar -->
            <RowDefinition Height="40"/>
            <!-- Main Content -->
            <RowDefinition Height="*"/>
            <!-- Status Bar -->
            <RowDefinition Height="28"/>
        </Grid.RowDefinitions>

        <!-- ═══════════════════════════════════════════ -->
        <!-- TOP NAVIGATION BAR                         -->
        <!-- ═══════════════════════════════════════════ -->
        <Border Grid.Row="0" Background="{StaticResource BgPanel}" 
                BorderBrush="{StaticResource Border}" BorderThickness="0,0,0,1">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                
                <!-- Logo / Brand -->
                <StackPanel Grid.Column="0" Orientation="Horizontal" Margin="12,0">
                    <TextBlock Text="◈" FontSize="18" Foreground="{StaticResource Primary}" 
                               VerticalAlignment="Center" Margin="0,0,8,0"/>
                    <TextBlock Text="H A N D V I S I O N" FontSize="12" FontWeight="Bold" 
                               Foreground="{StaticResource TextPrimary}" VerticalAlignment="Center"
                               FontFamily="Segoe UI"/>
                    <TextBlock Text="v1.0" FontSize="10" Foreground="{StaticResource TextMuted}" 
                               VerticalAlignment="Center" Margin="8,2,0,0"/>
                </StackPanel>
                
                <!-- Center — Connection Status -->
                <StackPanel Grid.Column="1" Orientation="Horizontal" HorizontalAlignment="Center">
                    <Border Background="{StaticResource BgSurface}" BorderBrush="{StaticResource Border}" 
                            BorderThickness="1" Padding="10,4" Margin="2,6">
                        <StackPanel Orientation="Horizontal">
                            <Ellipse x:Name="StatusDot" Width="8" Height="8" 
                                     Fill="{StaticResource TextMuted}" Margin="0,0,6,0"/>
                            <TextBlock x:Name="StatusText" Text="DISCONNECTED" FontSize="10" 
                                       FontWeight="SemiBold" Foreground="{StaticResource TextSecondary}"
                                       FontFamily="Segoe UI"/>
                        </StackPanel>
                    </Border>
                    
                    <Border Background="{StaticResource BgSurface}" BorderBrush="{StaticResource Border}" 
                            BorderThickness="1" Padding="10,4" Margin="2,6">
                        <TextBlock x:Name="FpsText" Text="FPS: —" FontSize="10" 
                                   Foreground="{StaticResource NeonCyan}" FontFamily="Consolas"/>
                    </Border>
                </StackPanel>
                
                <!-- Right — Controls -->
                <StackPanel Grid.Column="2" Orientation="Horizontal" Margin="12,0">
                    <Button x:Name="BtnToggleLeftPanel" Content="◧" FontSize="14"
                            Style="{StaticResource FlatButton}" Padding="8,4" Margin="2,6"
                            ToolTip="Toggle Left Panel" Click="BtnToggleLeftPanel_Click"/>
                    <Button x:Name="BtnToggleRightPanel" Content="◨" FontSize="14"
                            Style="{StaticResource FlatButton}" Padding="8,4" Margin="2,6"
                            ToolTip="Toggle Right Panel" Click="BtnToggleRightPanel_Click"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- ═══════════════════════════════════════════ -->
        <!-- MAIN CONTENT AREA                          -->
        <!-- ═══════════════════════════════════════════ -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <!-- Left Panel -->
                <ColumnDefinition x:Name="LeftPanelCol" Width="240"/>
                <!-- Camera View -->
                <ColumnDefinition Width="*"/>
                <!-- Right Panel -->
                <ColumnDefinition x:Name="RightPanelCol" Width="260"/>
            </Grid.ColumnDefinitions>

            <!-- ─── LEFT PANEL: Controls ─── -->
            <Border x:Name="LeftPanel" Grid.Column="0" Background="{StaticResource BgPanel}" 
                    BorderBrush="{StaticResource Border}" BorderThickness="0,0,1,0">
                <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="12,8">
                    <StackPanel>
                        
                        <!-- Section: Connection -->
                        <TextBlock Text="CONNECTION" Style="{StaticResource PanelLabel}"/>
                        <Border Background="{StaticResource BgSurface}" BorderBrush="{StaticResource Border}" 
                                BorderThickness="1" Padding="10,8" Margin="0,0,0,6">
                            <StackPanel>
                                <TextBlock Text="Python Engine" FontSize="11" Foreground="{StaticResource TextSecondary}" 
                                           FontFamily="Segoe UI"/>
                                <TextBlock x:Name="EngineStatus" Text="● Offline" FontSize="11" 
                                           Foreground="{StaticResource Error}" FontFamily="Segoe UI" Margin="0,4,0,0"/>
                            </StackPanel>
                        </Border>
                        
                        <Button x:Name="BtnConnect" Content="▶  START ENGINE" 
                                Style="{StaticResource AccentButton}" 
                                Margin="0,2,0,8" Click="BtnConnect_Click"/>
                        
                        <Button x:Name="BtnDisconnect" Content="■  STOP ENGINE" 
                                Style="{StaticResource FlatButton}" 
                                Margin="0,0,0,8" Click="BtnDisconnect_Click"
                                IsEnabled="False"/>
                        
                        <!-- Section: Display -->
                        <TextBlock Text="DISPLAY" Style="{StaticResource PanelLabel}"/>
                        <StackPanel Margin="0,0,0,4">
                            <ToggleButton x:Name="TglLandmarks" Content="● Landmarks" 
                                          Style="{StaticResource ToggleFlat}" IsChecked="True" 
                                          Margin="0,2" Click="TglLandmarks_Click"/>
                            <ToggleButton x:Name="TglSkeleton" Content="◇ Skeleton" 
                                          Style="{StaticResource ToggleFlat}" IsChecked="True" 
                                          Margin="0,2" Click="TglSkeleton_Click"/>
                            <ToggleButton x:Name="TglBoundingBox" Content="□ Bounding Box" 
                                          Style="{StaticResource ToggleFlat}" IsChecked="True" 
                                          Margin="0,2" Click="TglBoundingBox_Click"/>
                            <ToggleButton x:Name="TglMirror" Content="⇆ Mirror" 
                                          Style="{StaticResource ToggleFlat}" IsChecked="True" 
                                          Margin="0,2" Click="TglMirror_Click"/>
                        </StackPanel>
                        
                        <!-- Section: Detection -->
                        <TextBlock Text="DETECTION" Style="{StaticResource PanelLabel}"/>
                        <Border Background="{StaticResource BgSurface}" BorderBrush="{StaticResource Border}" 
                                BorderThickness="1" Padding="10,8" Margin="0,2,0,6">
                            <StackPanel>
                                <TextBlock Text="Confidence Threshold" FontSize="10" 
                                           Foreground="{StaticResource TextMuted}" FontFamily="Segoe UI"/>
                                <Grid Margin="0,4,0,0">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="40"/>
                                    </Grid.ColumnDefinitions>
                                    <Slider x:Name="SliderConfidence" Grid.Column="0" 
                                            Minimum="30" Maximum="95" Value="70"
                                            Style="{StaticResource FlatSlider}"
                                            ValueChanged="SliderConfidence_ValueChanged"/>
                                    <TextBlock x:Name="LblConfidence" Grid.Column="1" 
                                               Text="0.70" FontSize="11" Foreground="{StaticResource NeonCyan}" 
                                               FontFamily="Consolas" TextAlignment="Right" VerticalAlignment="Center"/>
                                </Grid>
                            </StackPanel>
                        </Border>

                        <!-- Section: Color Settings -->
                        <TextBlock Text="COLOR SETTINGS" Style="{StaticResource PanelLabel}"/>
                        <Border Background="{StaticResource BgSurface}" BorderBrush="{StaticResource Border}" 
                                BorderThickness="1" Padding="10,8" Margin="0,2,0,6">
                            <StackPanel>
                                <!-- White Balance Temperature -->
                                <TextBlock Text="White Balance (K)" FontSize="10" 
                                           Foreground="{StaticResource TextMuted}" FontFamily="Segoe UI"/>
                                <Grid Margin="0,4,0,6">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="45"/>
                                    </Grid.ColumnDefinitions>
                                    <Slider x:Name="SliderWbTemp" Grid.Column="0" 
                                            Minimum="2000" Maximum="10000" Value="6500"
                                            Style="{StaticResource FlatSlider}"
                                            ValueChanged="SliderWbTemp_ValueChanged"/>
                                    <TextBlock x:Name="LblWbTemp" Grid.Column="1" 
                                               Text="6500" FontSize="10" Foreground="{StaticResource NeonCyan}" 
                                               FontFamily="Consolas" TextAlignment="Right" VerticalAlignment="Center"/>
                                </Grid>
                                
                                <!-- Auto White Balance -->
                                <ToggleButton x:Name="TglAutoWb" Content="⚡ Auto White Balance" 
                                              Style="{StaticResource ToggleFlat}" IsChecked="False" 
                                              Margin="0,0,0,6" Click="TglAutoWb_Click"/>
                                
                                <!-- Brightness -->
                                <TextBlock Text="Brightness" FontSize="10" 
                                           Foreground="{StaticResource TextMuted}" FontFamily="Segoe UI"/>
                                <Grid Margin="0,4,0,6">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="35"/>
                                    </Grid.ColumnDefinitions>
                                    <Slider x:Name="SliderBrightness" Grid.Column="0" 
                                            Minimum="-100" Maximum="100" Value="0"
                                            Style="{StaticResource FlatSlider}"
                                            ValueChanged="SliderBrightness_ValueChanged"/>
                                    <TextBlock x:Name="LblBrightness" Grid.Column="1" 
                                               Text="0" FontSize="10" Foreground="{StaticResource NeonCyan}" 
                                               FontFamily="Consolas" TextAlignment="Right" VerticalAlignment="Center"/>
                                </Grid>
                                
                                <!-- Contrast -->
                                <TextBlock Text="Contrast" FontSize="10" 
                                           Foreground="{StaticResource TextMuted}" FontFamily="Segoe UI"/>
                                <Grid Margin="0,4,0,6">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="35"/>
                                    </Grid.ColumnDefinitions>
                                    <Slider x:Name="SliderContrast" Grid.Column="0" 
                                            Minimum="-100" Maximum="100" Value="0"
                                            Style="{StaticResource FlatSlider}"
                                            ValueChanged="SliderContrast_ValueChanged"/>
                                    <TextBlock x:Name="LblContrast" Grid.Column="1" 
                                               Text="0" FontSize="10" Foreground="{StaticResource NeonCyan}" 
                                               FontFamily="Consolas" TextAlignment="Right" VerticalAlignment="Center"/>
                                </Grid>
                                
                                <!-- Saturation -->
                                <TextBlock Text="Saturation" FontSize="10" 
                                           Foreground="{StaticResource TextMuted}" FontFamily="Segoe UI"/>
                                <Grid Margin="0,4,0,6">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="35"/>
                                    </Grid.ColumnDefinitions>
                                    <Slider x:Name="SliderSaturation" Grid.Column="0" 
                                            Minimum="-100" Maximum="100" Value="0"
                                            Style="{StaticResource FlatSlider}"
                                            ValueChanged="SliderSaturation_ValueChanged"/>
                                    <TextBlock x:Name="LblSaturation" Grid.Column="1" 
                                               Text="0" FontSize="10" Foreground="{StaticResource NeonCyan}" 
                                               FontFamily="Consolas" TextAlignment="Right" VerticalAlignment="Center"/>
                                </Grid>
                                
                                <!-- Hue -->
                                <TextBlock Text="Hue Shift" FontSize="10" 
                                           Foreground="{StaticResource TextMuted}" FontFamily="Segoe UI"/>
                                <Grid Margin="0,4,0,6">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="35"/>
                                    </Grid.ColumnDefinitions>
                                    <Slider x:Name="SliderHue" Grid.Column="0" 
                                            Minimum="-180" Maximum="180" Value="0"
                                            Style="{StaticResource FlatSlider}"
                                            ValueChanged="SliderHue_ValueChanged"/>
                                    <TextBlock x:Name="LblHue" Grid.Column="1" 
                                               Text="0" FontSize="10" Foreground="{StaticResource NeonCyan}" 
                                               FontFamily="Consolas" TextAlignment="Right" VerticalAlignment="Center"/>
                                </Grid>
                                
                                <!-- Gamma -->
                                <TextBlock Text="Gamma" FontSize="10" 
                                           Foreground="{StaticResource TextMuted}" FontFamily="Segoe UI"/>
                                <Grid Margin="0,4,0,6">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="40"/>
                                    </Grid.ColumnDefinitions>
                                    <Slider x:Name="SliderGamma" Grid.Column="0" 
                                            Minimum="10" Maximum="300" Value="100"
                                            Style="{StaticResource FlatSlider}"
                                            ValueChanged="SliderGamma_ValueChanged"/>
                                    <TextBlock x:Name="LblGamma" Grid.Column="1" 
                                               Text="1.00" FontSize="10" Foreground="{StaticResource NeonCyan}" 
                                               FontFamily="Consolas" TextAlignment="Right" VerticalAlignment="Center"/>
                                </Grid>
                                
                                <!-- Reset Button -->
                                <Button x:Name="BtnResetColor" Content="↺  RESET COLORS" 
                                        Style="{StaticResource FlatButton}" 
                                        Margin="0,2,0,0" Click="BtnResetColor_Click"/>
                            </StackPanel>
                        </Border>
                        
                        <!-- Section: Info -->
                        <TextBlock Text="ABOUT" Style="{StaticResource PanelLabel}"/>
                        <Border Background="{StaticResource BgSurface}" BorderBrush="{StaticResource Border}" 
                                BorderThickness="1" Padding="10,8">
                            <StackPanel>
                                <TextBlock Text="HandVision Prototype" FontSize="11" 
                                           Foreground="{StaticResource TextPrimary}" FontFamily="Segoe UI"/>
                                <TextBlock Text="C# WPF + Python OpenCV" FontSize="10" 
                                           Foreground="{StaticResource TextSecondary}" FontFamily="Segoe UI" Margin="0,2,0,0"/>
                                <TextBlock Text="MediaPipe Hand Tracking" FontSize="10" 
                                           Foreground="{StaticResource TextMuted}" FontFamily="Segoe UI" Margin="0,2,0,0"/>
                                <TextBlock FontSize="10" Foreground="{StaticResource TextMuted}" 
                                           FontFamily="Segoe UI" Margin="0,6,0,0" TextWrapping="Wrap">
                                    <Run Text="Architecture:"/>
                                    <LineBreak/>
                                    <Run Text="Python → TCP Socket → C# WPF" Foreground="{StaticResource TextSecondary}"/>
                                </TextBlock>
                            </StackPanel>
                        </Border>
                        
                    </StackPanel>
                </ScrollViewer>
            </Border>

            <!-- ─── CENTER: Camera View ─── -->
            <Grid Grid.Column="1" Background="#0A0B0E">
                <!-- Camera Frame -->
                <Image x:Name="CameraImage" Stretch="Uniform" 
                       RenderOptions.BitmapScalingMode="LowQuality"/>
                
                <!-- Placeholder when no frame -->
                <StackPanel x:Name="PlaceholderPanel" VerticalAlignment="Center" 
                            HorizontalAlignment="Center">
                    <TextBlock Text="◈" FontSize="64" Foreground="{StaticResource TextMuted}" 
                               HorizontalAlignment="Center" FontFamily="Segoe UI Symbol"/>
                    <TextBlock Text="HANDVISION" FontSize="22" FontWeight="Bold" 
                               Foreground="{StaticResource TextMuted}" HorizontalAlignment="Center"
                               FontFamily="Segoe UI" Margin="0,8,0,4"/>
                    <TextBlock Text="Press START ENGINE to begin tracking" FontSize="12" 
                               Foreground="{StaticResource TextMuted}" HorizontalAlignment="Center"
                               FontFamily="Segoe UI"/>
                </StackPanel>
            </Grid>

            <!-- ─── RIGHT PANEL: Hand Data ─── -->
            <Border x:Name="RightPanel" Grid.Column="2" Background="{StaticResource BgPanel}" 
                    BorderBrush="{StaticResource Border}" BorderThickness="1,0,0,0">
                <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="12,8">
                    <StackPanel>
                        
                        <!-- Section: Tracking Data -->
                        <TextBlock Text="TRACKING DATA" Style="{StaticResource PanelLabel}"/>
                        
                        <!-- Hand Count -->
                        <Border Background="{StaticResource BgSurface}" BorderBrush="{StaticResource Border}" 
                                BorderThickness="1" Padding="10,8" Margin="0,2,0,6">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="Hands Detected" FontSize="11" 
                                           Foreground="{StaticResource TextSecondary}" FontFamily="Segoe UI"/>
                                <TextBlock x:Name="HandCountText" Grid.Column="1" Text="0" FontSize="20" 
                                           FontWeight="Bold" Foreground="{StaticResource Primary}" 
                                           FontFamily="Consolas"/>
                            </Grid>
                        </Border>
                        
                        <!-- Hand 1 Info -->
                        <Border x:Name="Hand1Panel" Background="{StaticResource BgSurface}" 
                                BorderBrush="{StaticResource Border}" BorderThickness="1" 
                                Padding="10,8" Margin="0,2,0,6" Visibility="Collapsed">
                            <StackPanel>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock x:Name="Hand1Label" Text="HAND 1" FontSize="10" 
                                               FontWeight="SemiBold" Foreground="{StaticResource Accent}"
                                               FontFamily="Segoe UI"/>
                                    <TextBlock x:Name="Hand1Side" Grid.Column="1" Text="Right" FontSize="10" 
                                               Foreground="{StaticResource TextMuted}" FontFamily="Segoe UI"/>
                                </Grid>
                                
                                <TextBlock x:Name="Hand1Gesture" Text="—" FontSize="18" 
                                           FontWeight="Bold" Foreground="{StaticResource TextPrimary}" 
                                           FontFamily="Segoe UI" Margin="0,6,0,0"/>
                                
                                <TextBlock x:Name="Hand1Fingers" Text="Fingers: —" FontSize="11" 
                                           Foreground="{StaticResource TextSecondary}" FontFamily="Segoe UI" 
                                           Margin="0,4,0,0"/>
                                
                                <TextBlock x:Name="Hand1Confidence" Text="Confidence: —" FontSize="10" 
                                           Foreground="{StaticResource TextMuted}" FontFamily="Consolas" 
                                           Margin="0,4,0,0"/>
                                
                                <!-- Finger indicators -->
                                <StackPanel Orientation="Horizontal" Margin="0,8,0,0" HorizontalAlignment="Center">
                                    <Border x:Name="H1Thumb" Width="30" Height="30" Background="{StaticResource BgHover}" 
                                            BorderBrush="{StaticResource Border}" BorderThickness="1" Margin="2,0">
                                        <TextBlock Text="T" FontSize="12" FontWeight="Bold" 
                                                   HorizontalAlignment="Center" VerticalAlignment="Center"
                                                   Foreground="{StaticResource TextMuted}" FontFamily="Consolas"/>
                                    </Border>
                                    <Border x:Name="H1Index" Width="30" Height="30" Background="{StaticResource BgHover}" 
                                            BorderBrush="{StaticResource Border}" BorderThickness="1" Margin="2,0">
                                        <TextBlock Text="I" FontSize="12" FontWeight="Bold" 
                                                   HorizontalAlignment="Center" VerticalAlignment="Center"
                                                   Foreground="{StaticResource TextMuted}" FontFamily="Consolas"/>
                                    </Border>
                                    <Border x:Name="H1Middle" Width="30" Height="30" Background="{StaticResource BgHover}" 
                                            BorderBrush="{StaticResource Border}" BorderThickness="1" Margin="2,0">
                                        <TextBlock Text="M" FontSize="12" FontWeight="Bold" 
                                                   HorizontalAlignment="Center" VerticalAlignment="Center"
                                                   Foreground="{StaticResource TextMuted}" FontFamily="Consolas"/>
                                    </Border>
                                    <Border x:Name="H1Ring" Width="30" Height="30" Background="{StaticResource BgHover}" 
                                            BorderBrush="{StaticResource Border}" BorderThickness="1" Margin="2,0">
                                        <TextBlock Text="R" FontSize="12" FontWeight="Bold" 
                                                   HorizontalAlignment="Center" VerticalAlignment="Center"
                                                   Foreground="{StaticResource TextMuted}" FontFamily="Consolas"/>
                                    </Border>
                                    <Border x:Name="H1Pinky" Width="30" Height="30" Background="{StaticResource BgHover}" 
                                            BorderBrush="{StaticResource Border}" BorderThickness="1" Margin="2,0">
                                        <TextBlock Text="P" FontSize="12" FontWeight="Bold" 
                                                   HorizontalAlignment="Center" VerticalAlignment="Center"
                                                   Foreground="{StaticResource TextMuted}" FontFamily="Consolas"/>
                                    </Border>
                                </StackPanel>
                            </StackPanel>
                        </Border>
                        
                        <!-- Hand 2 Info -->
                        <Border x:Name="Hand2Panel" Background="{StaticResource BgSurface}" 
                                BorderBrush="{StaticResource Border}" BorderThickness="1" 
                                Padding="10,8" Margin="0,2,0,6" Visibility="Collapsed">
                            <StackPanel>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock x:Name="Hand2Label" Text="HAND 2" FontSize="10" 
                                               FontWeight="SemiBold" Foreground="{StaticResource Warning}"
                                               FontFamily="Segoe UI"/>
                                    <TextBlock x:Name="Hand2Side" Grid.Column="1" Text="Left" FontSize="10" 
                                               Foreground="{StaticResource TextMuted}" FontFamily="Segoe UI"/>
                                </Grid>
                                
                                <TextBlock x:Name="Hand2Gesture" Text="—" FontSize="18" 
                                           FontWeight="Bold" Foreground="{StaticResource TextPrimary}" 
                                           FontFamily="Segoe UI" Margin="0,6,0,0"/>
                                
                                <TextBlock x:Name="Hand2Fingers" Text="Fingers: —" FontSize="11" 
                                           Foreground="{StaticResource TextSecondary}" FontFamily="Segoe UI" 
                                           Margin="0,4,0,0"/>
                                
                                <TextBlock x:Name="Hand2Confidence" Text="Confidence: —" FontSize="10" 
                                           Foreground="{StaticResource TextMuted}" FontFamily="Consolas" 
                                           Margin="0,4,0,0"/>
                                
                                <!-- Finger indicators for hand 2 -->
                                <StackPanel Orientation="Horizontal" Margin="0,8,0,0" HorizontalAlignment="Center">
                                    <Border x:Name="H2Thumb" Width="30" Height="30" Background="{StaticResource BgHover}" 
                                            BorderBrush="{StaticResource Border}" BorderThickness="1" Margin="2,0">
                                        <TextBlock Text="T" FontSize="12" FontWeight="Bold" 
                                                   HorizontalAlignment="Center" VerticalAlignment="Center"
                                                   Foreground="{StaticResource TextMuted}" FontFamily="Consolas"/>
                                    </Border>
                                    <Border x:Name="H2Index" Width="30" Height="30" Background="{StaticResource BgHover}" 
                                            BorderBrush="{StaticResource Border}" BorderThickness="1" Margin="2,0">
                                        <TextBlock Text="I" FontSize="12" FontWeight="Bold" 
                                                   HorizontalAlignment="Center" VerticalAlignment="Center"
                                                   Foreground="{StaticResource TextMuted}" FontFamily="Consolas"/>
                                    </Border>
                                    <Border x:Name="H2Middle" Width="30" Height="30" Background="{StaticResource BgHover}" 
                                            BorderBrush="{StaticResource Border}" BorderThickness="1" Margin="2,0">
                                        <TextBlock Text="M" FontSize="12" FontWeight="Bold" 
                                                   HorizontalAlignment="Center" VerticalAlignment="Center"
                                                   Foreground="{StaticResource TextMuted}" FontFamily="Consolas"/>
                                    </Border>
                                    <Border x:Name="H2Ring" Width="30" Height="30" Background="{StaticResource BgHover}" 
                                            BorderBrush="{StaticResource Border}" BorderThickness="1" Margin="2,0">
                                        <TextBlock Text="R" FontSize="12" FontWeight="Bold" 
                                                   HorizontalAlignment="Center" VerticalAlignment="Center"
                                                   Foreground="{StaticResource TextMuted}" FontFamily="Consolas"/>
                                    </Border>
                                    <Border x:Name="H2Pinky" Width="30" Height="30" Background="{StaticResource BgHover}" 
                                            BorderBrush="{StaticResource Border}" BorderThickness="1" Margin="2,0">
                                        <TextBlock Text="P" FontSize="12" FontWeight="Bold" 
                                                   HorizontalAlignment="Center" VerticalAlignment="Center"
                                                   Foreground="{StaticResource TextMuted}" FontFamily="Consolas"/>
                                    </Border>
                                </StackPanel>
                            </StackPanel>
                        </Border>
                        
                        <!-- Section: Log -->
                        <TextBlock Text="ENGINE LOG" Style="{StaticResource PanelLabel}"/>
                        <Border Background="#0A0B0E" BorderBrush="{StaticResource Border}" 
                                BorderThickness="1" Height="180" Margin="0,2,0,0">
                            <ScrollViewer x:Name="LogScroller" VerticalScrollBarVisibility="Auto">
                                <TextBlock x:Name="LogText" FontSize="10" FontFamily="Consolas" 
                                           Foreground="{StaticResource TextMuted}" Padding="8,6"
                                           TextWrapping="Wrap"/>
                            </ScrollViewer>
                        </Border>
                        
                    </StackPanel>
                </ScrollViewer>
            </Border>
        </Grid>

        <!-- ═══════════════════════════════════════════ -->
        <!-- STATUS BAR                                 -->
        <!-- ═══════════════════════════════════════════ -->
        <Border Grid.Row="2" Background="{StaticResource BgPanel}" 
                BorderBrush="{StaticResource Border}" BorderThickness="0,1,0,0">
            <Grid Margin="12,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                
                <StackPanel Grid.Column="0" Orientation="Horizontal">
                    <Ellipse x:Name="StatusBarDot" Width="6" Height="6" 
                             Fill="{StaticResource TextMuted}" Margin="0,0,6,0" VerticalAlignment="Center"/>
                    <TextBlock x:Name="StatusBarText" Text="Ready" FontSize="10" 
                               Foreground="{StaticResource TextSecondary}" FontFamily="Segoe UI" 
                               VerticalAlignment="Center"/>
                </StackPanel>
                
                <TextBlock x:Name="FrameCountText" Grid.Column="2" Text="Frames: 0" FontSize="10" 
                           Foreground="{StaticResource TextMuted}" FontFamily="Consolas" 
                           VerticalAlignment="Center" Margin="12,0"/>
                
                <TextBlock x:Name="HandsStatusText" Grid.Column="3" Text="Hands: 0" FontSize="10" 
                           Foreground="{StaticResource TextMuted}" FontFamily="Consolas" 
                           VerticalAlignment="Center" Margin="12,0"/>
                
                <TextBlock x:Name="ResolutionText" Grid.Column="4" Text="640×480" FontSize="10" 
                           Foreground="{StaticResource TextMuted}" FontFamily="Consolas" 
                           VerticalAlignment="Center" Margin="12,0"/>
            </Grid>
        </Border>
    </Grid>
</Window>
